{
  "commands": [
    {
      "name": "publish",
      "description": "Publish files, folders, URLs, strings, or stdin.\nMultiple files are bundled into one drop.\nUse - to read stdin explicitly, or pipe without args.",
      "arguments": [
        "input"
      ],
      "options": [
        "--title",
        "--visibility",
        "--password",
        "--noindex",
        "--expires-at",
        "--content-type",
        "--entry",
        "--metadata",
        "--metadata-file",
        "--path",
        "--url",
        "--dry-run",
        "--json",
        "--idempotency-key"
      ],
      "auth": "required",
      "examples": [
        "dropthis ./report.html",
        "dropthis publish ./site --json",
        "dropthis publish ./site --url",
        "dropthis publish ./dist --dry-run"
      ]
    },
    {
      "name": "update-content",
      "description": "Replace a drop's content, same URL (pass the full drop_… id, not the slug).\nShips a new deployment. Settings stay unchanged — use update-settings for title, visibility, password, slug, expiry, or metadata.",
      "arguments": [
        "dropId",
        "input"
      ],
      "options": [
        "--entry",
        "--content-type",
        "--path",
        "--if-revision",
        "--url",
        "--dry-run",
        "--json",
        "--idempotency-key"
      ],
      "auth": "required",
      "examples": [
        "dropthis update-content drop_abc ./site --json"
      ]
    },
    {
      "name": "update-settings",
      "description": "Change a drop's title, visibility, password, vanity slug, expiry, or metadata (pass the full drop_… id, not the slug).\nContent stays unchanged — use update-content to replace the files at the URL.",
      "arguments": [
        "dropId"
      ],
      "options": [
        "--slug",
        "--title",
        "--visibility",
        "--password",
        "--no-password",
        "--noindex",
        "--index",
        "--expires-at",
        "--metadata",
        "--metadata-file",
        "--if-revision",
        "--url",
        "--dry-run",
        "--json",
        "--idempotency-key"
      ],
      "auth": "required",
      "examples": [
        "dropthis update-settings drop_abc --title 'Launch' --json"
      ]
    },
    {
      "name": "get",
      "description": "Show drop details (pass the full drop_… id)",
      "arguments": [
        "dropId"
      ],
      "options": [
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis get drop_abc --json"
      ]
    },
    {
      "name": "list",
      "description": "List your drops",
      "options": [
        "--limit",
        "--cursor",
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis list --json"
      ]
    },
    {
      "name": "delete",
      "description": "Delete a drop (pass the full drop_… id)",
      "arguments": [
        "dropId"
      ],
      "options": [
        "--yes",
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis delete drop_abc --yes --json"
      ]
    },
    {
      "name": "deployments",
      "description": "View deployment history",
      "auth": "required",
      "examples": [
        "dropthis deployments drop_abc --json"
      ],
      "subcommands": [
        {
          "name": "list",
          "description": "List deployments for a drop",
          "arguments": [
            "dropId"
          ],
          "options": [
            "--limit",
            "--cursor",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis deployments list drop_abc --json"
          ]
        },
        {
          "name": "get",
          "description": "Show deployment details",
          "arguments": [
            "dropId",
            "deploymentId"
          ],
          "options": [
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis deployments get drop_abc dep_abc --json"
          ]
        }
      ]
    },
    {
      "name": "api-keys",
      "description": "Manage API keys",
      "auth": "required",
      "examples": [
        "dropthis api-keys create --label CI --json"
      ],
      "subcommands": [
        {
          "name": "create",
          "description": "Create an API key",
          "options": [
            "--label",
            "--json"
          ]
        },
        {
          "name": "list",
          "description": "List API keys",
          "options": [
            "--json"
          ]
        },
        {
          "name": "delete",
          "description": "Delete an API key",
          "arguments": [
            "keyId"
          ],
          "options": [
            "--yes",
            "--json"
          ]
        }
      ]
    },
    {
      "name": "login",
      "description": "Authenticate with email OTP",
      "options": [
        "--email",
        "--otp",
        "--json"
      ],
      "examples": [
        "dropthis login verify --email user@example.com --otp 123456 --json"
      ],
      "subcommands": [
        {
          "name": "request",
          "description": "Request an email OTP",
          "options": [
            "--email",
            "--json"
          ]
        },
        {
          "name": "verify",
          "description": "Verify email OTP and store an API key",
          "options": [
            "--email",
            "--otp",
            "--json"
          ]
        }
      ]
    },
    {
      "name": "logout",
      "description": "Remove stored credentials",
      "options": [
        "--revoke",
        "--json"
      ],
      "examples": [
        "dropthis logout --json"
      ]
    },
    {
      "name": "whoami",
      "description": "Show current authentication status",
      "options": [
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis whoami --json"
      ]
    },
    {
      "name": "account",
      "description": "Show or manage your account",
      "auth": "required",
      "examples": [
        "dropthis account --json"
      ],
      "subcommands": [
        {
          "name": "get",
          "description": "Show account details",
          "options": [
            "--json"
          ],
          "auth": "required"
        },
        {
          "name": "update",
          "description": "Update account display name",
          "options": [
            "--display-name",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis account update --display-name 'Ada' --json"
          ]
        },
        {
          "name": "delete",
          "description": "Delete your account",
          "options": [
            "--yes",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis account delete --yes --json"
          ]
        }
      ]
    },
    {
      "name": "doctor",
      "description": "Report CLI diagnostics",
      "options": [
        "--json"
      ],
      "examples": [
        "dropthis doctor --json"
      ]
    },
    {
      "name": "commands",
      "description": "Print machine-readable command metadata",
      "options": [
        "--json"
      ],
      "examples": [
        "dropthis commands --json"
      ]
    }
  ]
}
