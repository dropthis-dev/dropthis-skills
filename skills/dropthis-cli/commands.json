{
  "commands": [
    {
      "name": "publish",
      "description": "Publish content to a permanent public URL (also: share, post, put online, make public, get a link).\nFiles, folders, URLs, strings, or stdin; multiple files bundle into one drop. Use - for stdin, or pipe without args.\nCreates a NEW drop each run — to change one you already published, use update-content (the files) or update-settings (title/visibility/password/expiry/metadata) with its drop_… id, not publish again.",
      "arguments": [
        "input"
      ],
      "options": [
        "--title",
        "--visibility",
        "--password",
        "--noindex",
        "--expires-at",
        "--content-type",
        "--entry",
        "--metadata",
        "--metadata-file",
        "--path",
        "--domain",
        "--shared",
        "--slug",
        "--manifest",
        "--workspace",
        "--url",
        "--dry-run",
        "--json",
        "--idempotency-key"
      ],
      "auth": "required",
      "examples": [
        "dropthis ./report.html",
        "dropthis publish ./site --json",
        "dropthis publish ./site --url",
        "dropthis publish ./dist --dry-run",
        "dropthis publish ./report.html --workspace acme --json   # target a specific workspace (delegated keys only)"
      ]
    },
    {
      "name": "update-content",
      "description": "Replace a drop's content, same URL (pass the full drop_… id, not the slug).\nShips a new deployment. Settings stay unchanged — use update-settings for title, visibility, password, expiry, or metadata.",
      "arguments": [
        "dropId",
        "input"
      ],
      "options": [
        "--entry",
        "--content-type",
        "--path",
        "--manifest",
        "--mode",
        "--replace",
        "--delete-path",
        "--if-revision",
        "--url",
        "--dry-run",
        "--json",
        "--idempotency-key"
      ],
      "auth": "required",
      "examples": [
        "dropthis update-content drop_abc ./site --json"
      ]
    },
    {
      "name": "update-settings",
      "description": "Change a drop's title, visibility, password, expiry, or metadata (pass the full drop_… id, not the slug).\nContent stays unchanged — use update-content to replace the files at the URL.",
      "arguments": [
        "dropId"
      ],
      "options": [
        "--title",
        "--visibility",
        "--password",
        "--no-password",
        "--noindex",
        "--index",
        "--expires-at",
        "--metadata",
        "--metadata-file",
        "--if-revision",
        "--url",
        "--dry-run",
        "--json",
        "--idempotency-key"
      ],
      "auth": "required",
      "examples": [
        "dropthis update-settings drop_abc --title 'Launch' --json"
      ]
    },
    {
      "name": "pull",
      "description": "Download a drop's files into a local directory (accepts the drop_… id, the drop URL, or its slug).\nFetches the current deployment's file manifest and writes every file. Pull, edit, then update-content to ship the changes back to the same URL — also the rollback path.",
      "arguments": [
        "target"
      ],
      "options": [
        "--output",
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis pull drop_abc -o ./site",
        "dropthis pull https://abc123.dropthis.app"
      ]
    },
    {
      "name": "get",
      "description": "Show drop details (accepts the drop_… id, the drop URL, or its slug)",
      "arguments": [
        "dropId"
      ],
      "options": [
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis get drop_abc --json"
      ]
    },
    {
      "name": "resolve",
      "description": "Resolve a public drop URL or slug back to its drop_… id (accepts the id too).\nWrites are id-only — use this to recover the id from a URL, then update-content/update-settings/delete by that id.",
      "arguments": [
        "target"
      ],
      "options": [
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis resolve https://abc123.dropthis.app/",
        "dropthis resolve abc123 --json"
      ]
    },
    {
      "name": "list",
      "description": "List your drops",
      "options": [
        "--limit",
        "--cursor",
        "--domain",
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis list --json",
        "dropthis list --domain reports.example.com --json"
      ]
    },
    {
      "name": "delete",
      "description": "Delete a drop (accepts the drop_… id, the drop URL, or its slug)",
      "arguments": [
        "dropId"
      ],
      "options": [
        "--yes",
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis delete drop_abc --yes --json"
      ]
    },
    {
      "name": "deployments",
      "description": "View deployment history",
      "auth": "required",
      "examples": [
        "dropthis deployments list drop_abc --json"
      ],
      "subcommands": [
        {
          "name": "list",
          "description": "List deployments for a drop",
          "arguments": [
            "dropId"
          ],
          "options": [
            "--limit",
            "--cursor",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis deployments list drop_abc --json"
          ]
        },
        {
          "name": "get",
          "description": "Show deployment details",
          "arguments": [
            "dropId",
            "deploymentId"
          ],
          "options": [
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis deployments get drop_abc dep_abc --json"
          ]
        }
      ]
    },
    {
      "name": "domains",
      "description": "Manage custom domains. Loop: connect → create the CNAME at your DNS provider → verify --wait → publish --domain",
      "auth": "required",
      "examples": [
        "dropthis domains list --json"
      ],
      "subcommands": [
        {
          "name": "connect",
          "description": "Connect a custom domain. Returns DNS records to create at your provider.\nAfter adding them: dropthis domains verify <hostname> --wait",
          "arguments": [
            "hostname"
          ],
          "options": [
            "--mode",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis domains connect reports.example.com --mode path --json"
          ]
        },
        {
          "name": "list",
          "description": "List connected custom domains",
          "options": [
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis domains list --json"
          ]
        },
        {
          "name": "status",
          "description": "Show domain details and DNS record status",
          "arguments": [
            "hostname"
          ],
          "options": [
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis domains status reports.example.com --json"
          ]
        },
        {
          "name": "verify",
          "description": "Trigger a DNS verification check. With --wait, polls until live or failed.\nUse after adding the DNS records from: dropthis domains connect\n\nExit codes: 0=live, 1=failed, 6=still pending (retry). Use --wait to poll automatically.",
          "arguments": [
            "hostname"
          ],
          "options": [
            "--wait",
            "--timeout",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis domains verify reports.example.com --wait --json"
          ]
        },
        {
          "name": "update",
          "description": "Update a domain — repoint to a different drop (dedicated mode) or set/clear as account default (path mode). At least one option required.",
          "arguments": [
            "hostname"
          ],
          "options": [
            "--drop",
            "--default",
            "--no-default",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis domains update reports.example.com --default --json"
          ]
        },
        {
          "name": "remove",
          "description": "Remove a custom domain (unmounts its drops). IMPORTANT: also delete the DNS CNAME at your provider to prevent DNS hijacking.",
          "arguments": [
            "hostname"
          ],
          "options": [
            "--yes",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis domains remove reports.example.com --yes --json"
          ]
        }
      ]
    },
    {
      "name": "api-keys",
      "description": "Manage API keys",
      "auth": "required",
      "examples": [
        "dropthis api-keys create --label CI --json"
      ],
      "subcommands": [
        {
          "name": "create",
          "description": "Create an API key",
          "options": [
            "--label",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis api-keys create --label CI --json"
          ]
        },
        {
          "name": "list",
          "description": "List API keys",
          "options": [
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis api-keys list --json"
          ]
        },
        {
          "name": "delete",
          "description": "Delete an API key",
          "arguments": [
            "keyId"
          ],
          "options": [
            "--yes",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis api-keys delete key_abc --yes --json"
          ]
        }
      ]
    },
    {
      "name": "workspace",
      "description": "Manage workspaces. Switch your active workspace (delegated keys only) or list all workspaces you belong to.",
      "auth": "required",
      "examples": [
        "dropthis workspace list --json",
        "dropthis workspace use acme"
      ],
      "subcommands": [
        {
          "name": "list",
          "description": "List workspaces you belong to",
          "options": [
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis workspace list --json"
          ]
        },
        {
          "name": "use",
          "description": "Switch your active workspace (server-side, persists on the credential). Delegated keys only — pinned service keys cannot switch.",
          "arguments": [
            "slugOrId"
          ],
          "options": [
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis workspace use acme",
            "dropthis workspace use ws_team123"
          ]
        }
      ]
    },
    {
      "name": "keys",
      "description": "Mint API keys (delegated login keys or pinned CI service keys)",
      "auth": "required",
      "examples": [
        "dropthis keys create --service --workspace acme --json"
      ],
      "subcommands": [
        {
          "name": "create",
          "description": "Create an API key. Without --service, mints a delegated account-scoped key (default for login). With --service --workspace <ws>, mints a CI key pinned to that workspace.",
          "options": [
            "--label",
            "--service",
            "--workspace",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis keys create --json",
            "dropthis keys create --service --workspace acme --json"
          ]
        }
      ]
    },
    {
      "name": "login",
      "description": "Authenticate with email OTP",
      "options": [
        "--email",
        "--otp",
        "--json"
      ],
      "examples": [
        "dropthis login",
        "dropthis login request --email user@example.com --json",
        "dropthis login verify --email user@example.com --otp 123456 --json"
      ],
      "subcommands": [
        {
          "name": "request",
          "description": "Request an email OTP",
          "options": [
            "--email",
            "--json"
          ],
          "examples": [
            "dropthis login request --email user@example.com --json"
          ]
        },
        {
          "name": "verify",
          "description": "Verify email OTP and store an API key",
          "options": [
            "--email",
            "--otp",
            "--json"
          ],
          "examples": [
            "dropthis login verify --email user@example.com --otp 123456 --json"
          ]
        }
      ]
    },
    {
      "name": "logout",
      "description": "Remove stored credentials",
      "options": [
        "--revoke",
        "--json"
      ],
      "examples": [
        "dropthis logout --json"
      ]
    },
    {
      "name": "whoami",
      "description": "Show current authentication status",
      "options": [
        "--json"
      ],
      "auth": "required",
      "examples": [
        "dropthis whoami --json"
      ]
    },
    {
      "name": "account",
      "description": "Show or manage your account",
      "auth": "required",
      "examples": [
        "dropthis account --json"
      ],
      "subcommands": [
        {
          "name": "get",
          "description": "Show account details",
          "options": [
            "--json"
          ],
          "auth": "required"
        },
        {
          "name": "update",
          "description": "Update account display name",
          "options": [
            "--display-name",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis account update --display-name 'Ada' --json"
          ]
        },
        {
          "name": "delete",
          "description": "Delete your account",
          "options": [
            "--yes",
            "--json"
          ],
          "auth": "required",
          "examples": [
            "dropthis account delete --yes --json"
          ]
        }
      ]
    },
    {
      "name": "doctor",
      "description": "Report CLI diagnostics",
      "options": [
        "--json"
      ],
      "examples": [
        "dropthis doctor --json"
      ]
    },
    {
      "name": "upgrade",
      "description": "Update the CLI to the latest version from npm",
      "options": [
        "--json"
      ],
      "examples": [
        "dropthis upgrade",
        "dropthis upgrade --json"
      ]
    },
    {
      "name": "commands",
      "description": "Print machine-readable command metadata",
      "options": [
        "--json"
      ],
      "examples": [
        "dropthis commands --json"
      ]
    }
  ]
}
